---
import Layout from '@layouts/Layout.astro';
import AppPage from '@components/AppPage.astro';
import { appEntries, getAppBySlug } from '../../data/apps';

export function getStaticPaths() {
  return appEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const app = getAppBySlug(entry.slug);
---

<Layout>
  <AppPage title={app?.title ?? ''} tagline={app?.tagline ?? ''}>
    <div class="card mx-auto max-w-lg p-8 space-y-2 border border-surface-200-800 text-center">
      <p class="text-sm opacity-50">coming soon</p>
      <p class="text-sm text-surface-600-400">{app?.description}</p>
    </div>
  </AppPage>
</Layout>
