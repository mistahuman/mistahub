---
import Layout from '@layouts/Layout.astro';

const mistatoolsUrl = 'https://mistahuman.github.io/mistatools';
---

<Layout>
  <meta http-equiv="refresh" content={`0; url=${mistatoolsUrl}`} slot="head" />
  <div class="container mx-auto flex max-w-xl flex-col items-center gap-6 px-4 py-24 text-center">
    <p class="text-sm text-surface-600-400">mistadiff has moved</p>
    <h1 class="text-3xl font-bold">mistatools</h1>
    <p class="text-surface-600-400">
      The formatter and differ — along with an API client — now live in one unified tool suite.
    </p>
    <a href={mistatoolsUrl} class="btn preset-filled-primary-500">Go to mistatools →</a>
  </div>
</Layout>
