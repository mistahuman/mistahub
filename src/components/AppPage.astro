---
import { ChevronLeft } from 'lucide-svelte';

interface Props {
  title: string;
  tagline: string;
  sourceUrl?: string;
  sourceLabel?: string;
}

const { title, tagline, sourceUrl, sourceLabel = 'Data source' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<div class="container mx-auto max-w-screen-xl px-4 py-8 md:px-8 md:py-10 xl:px-10">
  <div class="mb-8 flex flex-col gap-5 md:mb-10 md:flex-row md:items-end md:justify-between">
    <div class="space-y-4">
      <a href={base} class="btn btn-sm preset-tonal w-fit">
        <ChevronLeft size={16} />
        mistahub
      </a>

      <div class="space-y-2">
        <h1 class="h2">{title}</h1>
        <p class="max-w-2xl text-sm leading-relaxed text-surface-600-400 md:text-base">{tagline}</p>
        {
          sourceUrl && (
            <a
              href={sourceUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex w-fit text-sm font-semibold text-primary-600-400 hover:underline"
            >
              {sourceLabel}
            </a>
          )
        }
      </div>
    </div>
  </div>

  <slot />
</div>
