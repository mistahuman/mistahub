---
import { ChevronLeft } from 'lucide-svelte';

interface Props {
  title: string;
  tagline: string;
}

const { title, tagline } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<div class="container mx-auto max-w-screen-lg px-4 py-10 md:px-8 xl:px-10">
  <a href={base} class="btn btn-sm preset-tonal">
    <ChevronLeft size={16} />
    mistahub
  </a>

  <div class="mt-8 mb-8 text-center">
    <h1 class="h2">{title}</h1>
    <p class="text-surface-600-400 text-sm mt-1">{tagline}</p>
  </div>

  <slot />
</div>
