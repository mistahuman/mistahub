---
import {
  Globe,
  Eye,
  TrendingUp,
  Type,
  Spade,
  Landmark,
  Newspaper,
  Building2,
  ArrowLeftRight,
  Wind,
  CloudSun,
  CalendarDays,
  Radio,
  Boxes,
  Wrench,
  Replace,
  Star,
  Plus,
  ExternalLink,
} from 'lucide-svelte';
import { appEntries } from '../data/apps';

const base = import.meta.env.BASE_URL;
const categoryOrder = ['news', 'dev', 'tool', 'data', 'art', 'game'] as const;
const categoryMeta = {
  dev: {
    label: 'dev',
    description: 'Developer utilities and in-browser tooling.',
  },
  game: {
    label: 'games',
    description: 'Fast rounds, streaks, and small challenges.',
  },
  news: {
    label: 'news',
    description: 'Live feeds and attention signals.',
  },
  tool: {
    label: 'tools',
    description: 'Utilities for quick answers.',
  },
  data: {
    label: 'data',
    description: 'Public datasets turned into readable views.',
  },
  art: {
    label: 'art',
    description: 'Daily discovery and visual picks.',
  },
};

const icons = {
  mistageo: Globe,
  mistadex: Eye,
  mistahypedia: TrendingUp,
  mistaword: Type,
  mistajack: Spade,
  mistamuseum: Landmark,
  mistanews: Newspaper,
  mistagov: Building2,
  mistaexchange: ArrowLeftRight,
  mistaair: Wind,
  mistaweather: CloudSun,
  mistabolo: CalendarDays,
  mistaradio: Radio,
  mistaoss: Boxes,
  mistatools: Wrench,
  mistastrings: Replace,
};
---

<section class="container mx-auto max-w-screen-xl px-4 py-12 md:px-8 md:py-16 xl:px-10">
  <div class="space-y-6">
    <span class="badge preset-tonal-secondary w-fit">personal lab</span>
    <div class="space-y-3">
      <h1 class="text-4xl font-bold leading-tight md:text-6xl">mistahub</h1>
      <p class="max-w-xl text-base leading-relaxed text-surface-600-400 md:text-lg">
        Small tools, games, and live data experiments in one place.
      </p>
    </div>
    <div class="flex flex-wrap gap-2">
      {
        categoryOrder.map((cat) => {
          const count = appEntries.filter((e) => e.category === cat && e.status === 'ready').length;
          if (count === 0) return null;
          return (
            <button
              data-filter-btn
              data-filter-cat={cat}
              class="badge preset-outlined-primary-500 cursor-pointer transition hover:preset-tonal-primary"
            >
              {count} {categoryMeta[cat].label}
            </button>
          );
        })
      }
    </div>
  </div>

  <div class="mt-10 space-y-10">
    {
      categoryOrder.map((category) => {
        const entries = appEntries.filter((entry) => entry.category === category);
        if (entries.length === 0) return null;

        return (
          <section
            data-filter-section
            data-filter-cat={category}
            class="space-y-4"
            aria-labelledby={`hub-${category}`}
          >
            <div>
              <h2 id={`hub-${category}`} class="text-xl font-semibold">
                {categoryMeta[category].label}
              </h2>
              <p class="text-sm text-surface-600-400">{categoryMeta[category].description}</p>
            </div>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {entries.map((entry) => {
                const Icon = icons[entry.slug as keyof typeof icons] ?? Plus;
                return (
                  <a
                    href={entry.externalUrl ?? `${base}apps/${entry.slug}/`}
                    target={entry.externalUrl ? '_blank' : undefined}
                    rel={entry.externalUrl ? 'noopener noreferrer' : undefined}
                    class="group card block border border-surface-200-800 bg-surface-50-950 p-5 transition hover:border-primary-500/50 hover:shadow-xl"
                  >
                    <div class="flex min-h-full flex-col gap-5">
                      <div class="flex items-center justify-between">
                        <span class="rounded-base bg-primary-500/10 p-2 text-primary-600-400 w-fit">
                          <Icon size={24} />
                        </span>
                        <div class="flex items-center gap-1.5">
                          {entry.externalUrl && <ExternalLink size={12} class="text-surface-500" />}
                          <span class="badge preset-tonal-primary text-xs">{entry.category}</span>
                        </div>
                      </div>
                      <div class="space-y-2">
                        <h3 class="text-xl font-semibold">{entry.title}</h3>
                        <p class="text-sm leading-relaxed text-surface-600-400">
                          {entry.description}
                        </p>
                      </div>
                      <div class="mt-auto flex items-baseline gap-1 text-sm text-surface-500">
                        <span class="flex shrink-0 translate-y-[1px]">
                          <Star size={12} />
                        </span>
                        <span class="tabular-nums leading-none">{entry.stars}</span>
                      </div>
                    </div>
                  </a>
                );
              })}
            </div>
          </section>
        );
      })
    }

    <div
      id="hub-coming-soon"
      class="card flex min-h-56 flex-col items-center justify-center gap-3 border border-dashed border-surface-300-700 bg-surface-50-950 p-5 text-center text-surface-500"
    >
      <Plus size={26} />
      <p class="text-sm font-semibold">more coming soon</p>
      <p class="max-w-48 text-xs leading-relaxed">
        New experiments will land here when they are ready.
      </p>
    </div>
  </div>
</section>

<script>
  const selected = new Set<string>();
  const btns = document.querySelectorAll<HTMLButtonElement>('[data-filter-btn]');
  const sections = document.querySelectorAll<HTMLElement>('[data-filter-section]');
  const comingSoon = document.getElementById('hub-coming-soon');

  function applyFilter() {
    btns.forEach((btn) => {
      const active = selected.has(btn.dataset.filterCat!);
      btn.classList.toggle('preset-filled-primary-500', active);
      btn.classList.toggle('preset-outlined-primary-500', !active);
    });

    const showAll = selected.size === 0;
    sections.forEach((section) => {
      const visible = showAll || selected.has(section.dataset.filterCat!);
      section.style.display = visible ? '' : 'none';
    });

    if (comingSoon) comingSoon.style.display = showAll ? '' : 'none';
  }

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.filterCat!;
      if (selected.has(cat)) {
        selected.delete(cat);
      } else {
        selected.add(cat);
      }
      applyFilter();
    });
  });
</script>
