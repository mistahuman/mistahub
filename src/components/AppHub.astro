---
import {
  Globe,
  Eye,
  TrendingUp,
  Type,
  Spade,
  Landmark,
  Newspaper,
  Building2,
  ArrowLeftRight,
  Wind,
  CloudSun,
  CalendarDays,
  Radio,
  Boxes,
  Plus,
} from 'lucide-svelte';
import { appEntries } from '../data/apps';

const base = import.meta.env.BASE_URL;
const readyApps = appEntries.filter((entry) => entry.status === 'ready');
const plannedApps = appEntries.filter((entry) => entry.status === 'planned');
const categories = [...new Set(appEntries.map((entry) => entry.category))];
const categoryOrder = ['news', 'tool', 'data', 'art', 'game'] as const;
const categoryMeta = {
  game: {
    label: 'games',
    description: 'Fast rounds, streaks, and small challenges.',
  },
  news: {
    label: 'news',
    description: 'Live feeds and attention signals.',
  },
  tool: {
    label: 'tools',
    description: 'Utilities for quick answers.',
  },
  data: {
    label: 'data',
    description: 'Public datasets turned into readable views.',
  },
  art: {
    label: 'art',
    description: 'Daily discovery and visual picks.',
  },
};

const icons = {
  mistageo: Globe,
  mistadex: Eye,
  mistahypedia: TrendingUp,
  mistaword: Type,
  mistajack: Spade,
  mistamuseum: Landmark,
  mistanews: Newspaper,
  mistagov: Building2,
  mistaexchange: ArrowLeftRight,
  mistaair: Wind,
  mistaweather: CloudSun,
  mistabolo: CalendarDays,
  mistaradio: Radio,
  mistaoss: Boxes,
};
---

<section class="container mx-auto max-w-screen-xl px-4 py-12 md:px-8 md:py-16 xl:px-10">
  <div class="grid gap-8 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.6fr)] lg:items-end">
    <div class="space-y-5">
      <span class="badge preset-tonal-secondary w-fit">personal lab</span>
      <div class="space-y-3">
        <h1 class="text-4xl font-bold leading-tight md:text-6xl">mistahub</h1>
        <p class="max-w-xl text-base leading-relaxed text-surface-600-400 md:text-lg">
          Small tools, games, and live data experiments in one place.
        </p>
      </div>
    </div>

    <div class="grid gap-3 sm:grid-cols-3">
      <div class="border-surface-200-800 bg-surface-50-950 rounded-container border p-4">
        <p class="text-3xl font-bold tabular-nums">{readyApps.length}</p>
        <p class="mt-1 text-xs uppercase tracking-wide text-surface-500">ready apps</p>
      </div>
      <div class="border-surface-200-800 bg-surface-50-950 rounded-container border p-4">
        <p class="text-3xl font-bold tabular-nums">{plannedApps.length}</p>
        <p class="mt-1 text-xs uppercase tracking-wide text-surface-500">planned</p>
      </div>
      <div class="border-surface-200-800 bg-surface-50-950 rounded-container border p-4">
        <p class="text-3xl font-bold tabular-nums">{categories.length}</p>
        <p class="mt-1 text-xs uppercase tracking-wide text-surface-500">tags</p>
      </div>
    </div>
  </div>

  <div class="mt-10 space-y-10">
    {
      categoryOrder.map((category) => {
        const entries = appEntries.filter((entry) => entry.category === category);
        if (entries.length === 0) return null;

        return (
          <section class="space-y-4" aria-labelledby={`hub-${category}`}>
            <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
              <div>
                <h2 id={`hub-${category}`} class="text-xl font-semibold">
                  {categoryMeta[category].label}
                </h2>
                <p class="text-sm text-surface-600-400">{categoryMeta[category].description}</p>
              </div>
              <div
                class="border-primary-500/30 bg-primary-500/10 rounded-container flex w-fit items-baseline gap-2 border px-3 py-2 text-primary-600-400"
                aria-label={`${entries.length} apps in ${categoryMeta[category].label}`}
              >
                <span class="text-2xl font-bold leading-none tabular-nums">{entries.length}</span>
                <span class="text-xs font-semibold uppercase tracking-wide">
                  {entries.length === 1 ? 'app' : 'apps'}
                </span>
              </div>
            </div>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {entries.map((entry) => {
                const Icon = icons[entry.slug as keyof typeof icons] ?? Plus;
                return (
                  <a
                    href={`${base}apps/${entry.slug}/`}
                    class="group card block border border-surface-200-800 bg-surface-50-950 p-5 transition hover:border-primary-500/50 hover:shadow-xl"
                  >
                    <div class="flex min-h-full flex-col gap-5">
                      <div class="flex items-start justify-between gap-3">
                        <span class="rounded-base bg-primary-500/10 p-2 text-primary-600-400">
                          <Icon size={24} />
                        </span>
                        <span class="badge preset-tonal-surface text-[0.68rem]">
                          {categoryMeta[entry.category].label}
                        </span>
                      </div>
                      <div class="space-y-2">
                        <h3 class="text-xl font-semibold">{entry.title}</h3>
                        <p class="text-sm leading-relaxed text-surface-600-400">
                          {entry.description}
                        </p>
                      </div>
                      <span class="mt-auto inline-flex items-center text-sm font-semibold text-primary-600-400">
                        Open
                        <span class="ml-1 transition-transform group-hover:translate-x-1">→</span>
                      </span>
                    </div>
                  </a>
                );
              })}
            </div>
          </section>
        );
      })
    }

    <div
      class="card flex min-h-56 flex-col items-center justify-center gap-3 border border-dashed border-surface-300-700 bg-surface-50-950 p-5 text-center text-surface-500"
    >
      <Plus size={26} />
      <p class="text-sm font-semibold">more coming soon</p>
      <p class="max-w-48 text-xs leading-relaxed">
        New experiments will land here when they are ready.
      </p>
    </div>
  </div>
</section>
