---
import { Plus } from 'lucide-svelte';
import { appEntries } from '../data/apps';

const base = import.meta.env.BASE_URL;
---

<section class="container mx-auto max-w-screen-lg px-4 py-14 md:px-8 xl:px-10">
  <div class="mb-10">
    <h1 class="text-4xl font-bold md:text-5xl">mistahub</h1>
    <p class="mt-2 text-surface-600-400">small tools and games, all in one place.</p>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      appEntries.map((entry) => {
        const Icon = entry.icon;
        return (
          <a
            href={`${base}apps/${entry.slug}/`}
            class="card p-5 space-y-4 transition-shadow hover:shadow-xl border-[1px] border-surface-200-800 card-hover block"
          >
            <Icon size={28} />
            <h2 class="text-xl font-semibold">{entry.title}</h2>
            <p class="text-sm text-surface-600-400">{entry.tagline}</p>
            <button type="button" class="btn btn-sm preset-filled">
              lets go
            </button>
          </a>
        );
      })
    }

    <!-- coming soon placeholder -->
    <div
      class="card p-5 space-y-4 border-[1px] border-surface-200-800 border-dashed opacity-40 flex flex-col justify-center items-center text-center"
    >
      <Plus size={28} />
      <p class="text-sm">more coming soon</p>
    </div>
  </div>
</section>
